{
  "name": "pollinate",
  "version": "1.0.0",
  "description": "Standalone trigger substrate for schedules, polls, webhooks, and fired actions.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pollinate": "dist/cli.js",
    "pol": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "PRD.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm build",
    "test": "vitest run --pool threads --no-file-parallelism",
    "typecheck:tests": "tsc -p tsconfig.tests.json",
    "lint": "biome check .",
    "check": "pnpm build && pnpm typecheck:tests && pnpm lint && pnpm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "jsonpath-plus": "^10.4.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
